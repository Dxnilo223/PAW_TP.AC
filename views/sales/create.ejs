<%- include('../partials/head') %>
<%- include('../partials/nav') %>

<div class="container mt-4">

  <h1>Create Sale</h1>

  <form action="/sales/create" method="POST">

    <!-- CUSTOMER -->
    <label>Customer Email:</label><br>
    <input type="email" name="customerEmail" required class="form-control mb-3">

    <h3>Products</h3>

    <% if (products.length === 0) { %>
      <p>No products available.</p>
    <% } else { %>

      <% products.forEach(product => { %>
        <div class="mb-2">

          <!-- product info -->
          <strong><%= product.name %></strong> 
          (€<%= product.price %>)

          <!-- hidden id -->
          <input 
            type="hidden" 
            name="productIds[]" 
            value="<%= product._id %>"
          >

          <!-- quantity -->
          <input 
            type="number" 
            name="quantities[]" 
            min="0" 
            value="0"
            data-price="<%= product.price %>"
            class="form-control"
          >

        </div>
      <% }) %>

      <!-- TOTAL FORA DO LOOP -->
      <h3 class="mt-3">Total: €<span id="total">0.00</span></h3>

    <% } %>

    <br>

    <button type="submit" class="btn btn-success">Complete Sale</button>

  </form>

</div>

<!-- SCRIPT -->
<script>
  const inputs = document.querySelectorAll('input[name="quantities[]"]');

  function calculateTotal() {
    let total = 0;

    inputs.forEach(input => {
      const qty = parseInt(input.value) || 0;
      const price = parseFloat(input.dataset.price) || 0;

      total += qty * price;
    });

    document.getElementById('total').innerText = total.toFixed(2);
  }

  inputs.forEach(input => {
    input.addEventListener('input', calculateTotal);
  });
</script>

<%- include('../partials/foot') %>